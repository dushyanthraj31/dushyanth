<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="loginpagemvvm.views.StudentMarklistPage"
             Title="StudentMarklistPage">
    <CollectionView ItemsSource="{Binding Students}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10">
                    <HorizontalStackLayout>
                        
                        <Label Text="Name" FontSize="18"/>
                        <Label Text="{Binding Name}"/>
                        <Label  Text=""/>
                        <Label Text="Tamilmark" FontSize="18"/>
                        <Label Text="{Binding Tamil}"/>
                        <Label  Text=""/>
                        <Label Text="Englishmark" FontSize="18"/>
                        <Label Text="{Binding English}"/>
                        <Label  Text=""/>
                        <Label Text="Mathsmark" FontSize="18"/>
                        <Label Text="{Binding Maths}"/>
                        <Label  Text=""/>
                        <Label Text="Total" FontSize="18"/>
                        <Label Text="{Binding Total}"/>

                    </HorizontalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>