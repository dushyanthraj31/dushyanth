<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="loginpagemvvm.views.loginPage"
             BackgroundColor="White">

    <Grid ColumnDefinitions="*,2*" RowDefinitions="*">

        <!-- LEFT PANEL -->
        <Grid BackgroundColor="#1976D2" Grid.Column="0">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">

                <Label Text="Welcome User!"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Image Source="dotnet_bot.png"
                       HeightRequest="100"
                       WidthRequest="100"
                       Margin="0,20"/>

                <Label Text="Developed by You"
                       TextColor="White"
                       FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- RIGHT PANEL -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="30" Spacing="15">

                <Label Text="School Management System"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1976D2"/>

                <Label Text="Login Page"
                       FontSize="18"
                       FontAttributes="Bold"/>

                <!-- Username -->
                <Label Text="User Name"/>
                
                <Frame BorderColor="Gray" CornerRadius="8">
                    <Entry x:Name="usernameEntry" Placeholder="Enter username"/>
                </Frame>

                <!-- Password -->
                <Label Text="Password"/>
                <Frame BorderColor="Gray" CornerRadius="8">
                    <Entry x:Name="passwordEntry" Placeholder="Enter password" IsPassword="True"/>
                </Frame>

                <!-- User Type -->
                <Label Text="User Type"/>
                <Frame BorderColor="Gray" CornerRadius="8">
                    <Picker Title="Select User Type">
                        <Picker.Items>
                            <x:String>Admin</x:String>
                            <x:String>Student</x:String>
                            <x:String>Staff</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>

                <!-- Buttons -->
                <HorizontalStackLayout Spacing="20">

                    <Button Text="SUBMIT"
                            Command="{Binding LoginCommand}"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            WidthRequest="120"
                            CornerRadius="8"/>

                   
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>